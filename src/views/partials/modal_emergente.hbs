<style>
  .modal-dialog.custom-width {
    width: 60% !important;
    max-width: none !important;
  }

  @media (min-width: 768px) {
    .modal-lg {
      width: 60% !important;
    }
  }
</style>
<div class="modal fade bd-example-modal-lg" id="modal_emergente" role="dialog"
  aria-labelledby="myLargeModalLabel" aria-hidden="true">
  <div class="modal-dialog modal-lg custom-width">
    <div class="modal-content">
      <div class="modal-header">
        <strong>
          <h3 class="modal-title" id="titulo_emergente">TAREA EMERGENTE</h3>
        </strong>
      </div>
      <div class="modal-body">
        <div class="box-typical box-typical-padding">
          <section>
            <div class="card-block">
              <div class="row">
                <div class="col-md-3">
                  <label class="form-label" for="gerencia">Gerencia</label>
                  <select class="select2" name="gerencia" id="gerencia">
                    <option value="" disabled selected>Seleccione una gerencia</option>
                    {{#each gerencias}}
                    <option value="{{Id}}">{{Descripcion}}</option>
                    {{/each}}
                  </select>
                </div>
                <div class="col-md-3">
                  <label class="form-label" for="area">Area</label>
                  <select class="select2" name="area" id="area">
                    <option value="" disabled selected>Seleccione un área</option>
                  </select>
                </div>
                <div class="col-md-3">
                  <label class="form-label" for="sector">Sector</label>
                  <select class="select2" name="sector" id="sector">
                    <option value="" disabled selected>Seleccione un Sector</option>
                  </select>
                </div>
                <div class="col-md-3">
                  <label class="form-label" for="equipo">Equipo</label>
                  <select class="select2" name="equipo" id="equipo">
                    <option value="" disabled selected>Seleccione un equipo</option>
                  </select>
                </div>
              </div>
              <br>
              <div class="row">
                <div class="col-md-3">
                  <label class="form-label" for="fecha">Fecha</label>
                  <input class="form-control" type="date" name="fecha" id="fecha">
                </div>
                <div class="col-md-3">
                  <label class="form-label" for="tecnico">Técnico</label>
                  <select class="select2" name="tecnico" id="tecnico">
                    <option value="" disabled selected>Seleccione un técnico</option>
                    {{#each tecnicos}}
                    <option value="{{Id}}">{{Login}}</option>
                    {{/each}}
                  </select>
                </div>
                <div class="col-md-3">
                  <label class="form-label" for="protocolo">Protocolo</label>
                  <select class="select2" name="protocolo" id="protocolo">
                    <option value="" disabled selected>Seleccione un protocolo</option>
                  </select>
                </div>
                <div class="col-md-3">
                  <label class="form-label" for="tipo_emergente">Emergente*</label>
                  <select class="select2" name="tipo_emergente" id="tipo_emergente">
                    {{#each tipo_emergente}}
                    <option value="{{Id}}">{{Descripcion}}</option>
                    {{/each}}
                  </select>
                </div>
              </div>
              <br>
              <button class="btn btn-success float-right" id="crear">Crear</button>
            </div>
          </section>
        </div>
      </div>
    </div>
  </div>
</div>