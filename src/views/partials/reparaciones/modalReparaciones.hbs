<div class="modal fade bd-example-modal-lg" id="modalReparaciones" tabindex="-1" role="dialog" aria-labelledby="myLargeModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <button type="button" class="modal-close" data-dismiss="modal" aria-label="Close">
                    <i class="font-icon-close-2"></i>
                </button>
                <h2 class="modal-title" id="tituloReparaciones">Planificación de reparaciones</h2>
            </div>
            <div class="modal-body m-t-2">
                <div class="row">
                    <div class="col-md-12">
                        <div class="form-group">
                            <label class="form-label" for="inputFile">Seleccione un archivo</label>
                            <input type="file" class="form-control" id="inputFile" name="inputFile" accept=".xls,.xlsx,application/vnd.ms-excel,application/vnd.openxmlformats-officedocument.spreadsheetml.sheet">
                            <br>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="form-group">
                            <label class="form-label" for="mes">Mes</label>
                            <select class="form-control" name="mes" id="mes">
                                <option value="" disabled selected>Seleccione un mes</option>
                                    <option value="1">Enero</option>
                                    <option value="2">Febrero</option>
                                    <option value="3">Marzo</option>
                                    <option value="4">Abril</option>
                                    <option value="5">Mayo</option>
                                    <option value="6">Junio</option>
                                    <option value="7">Julio</option>
                                    <option value="8">Agosto</option>
                                    <option value="9">Septiembre</option>
                                    <option value="10">Octubre</option>
                                    <option value="11">Noviembre</option>
                                    <option value="12">Diciembre</option>
                            </select>
                            <br>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="form-group">
                            <label class="form-label" for="ano">Año</label>
                            <select class="form-control" name="ano" id="ano">
                                <option value="" disabled selected>Seleccione un año</option>
                            </select>
                            <br>
                        </div>
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-primary" id="subirArchivo">Planificar</button>
            </div>
        </div>
    </div>
</div>  