<body class="with-side-menu">
	{{> navbar }}
	<div class="mobile-menu-left-overlay-"></div>
	{{> nav }}
	<div class="page-content">
		<div class="container-fluid">
			<header class="section-header">
				<div class="tbl">
					<div class="tbl-row">
						<div class="tbl-cell">
							<h3>Equipos</h3>
							<ol class="breadcrumb breadcrumb-simple">
								<li><a href="/home">Inicio</a></li>
								<li class="active">Equipos</li>
								<li class="active">Ver</li>
							</ol>
						</div>
						<div class="form-group float-right">
                            <a href="/equiposnew" type="button" class="btn btn-inline btn-primary-outline">Nuevo</a>
                        </div>
					</div>
				</div>
				<style>
					.miClase {
						font-family: Verdana, Geneva, Tahoma, sans-serif;
						font-size: 10px; /* Cambia el tamaño de la fuente a 14px */
					}
					.dataTables_filter {
						float: left;
					}
					.dt-buttons {
						float: right;
					}
				</style>
			</header>
		</div>
		<section class="card box-typical">
			<div class="card-block m-b-1">
				<div class="col-md-3 position-relative">
					<label class="form-label" for="equipo">Buscar Equipo</label>
					<input type="text" class="form-control" id="equipo" name="equipo" placeholder="Ingrese un Tag, Serie o Certificación" autocomplete="off">
					<ul id="equipos-list" class="list-group position-absolute w-100" style="z-index:1000; display:none; max-height:200px; overflow-y:auto;"></ul>
				</div>
				<div class="col-md-3">
					<label class="form-label" for="buscarEquipo" style="color: aliceblue;">.</label>
					<button type="button" name="buscarEquipo" id="buscarEquipo" class="btn btn-primary">Buscar</button>
				</div>
				<div class="col-md-3">
				</div>
				<div class="col-md-3 float-right">
					<label class="form-label" for="nuevoEquipo" style="color: aliceblue;">.</label>
					<button type="button" name="bajaEquipo" id="bajaEquipo" class="btn btn-danger float-right m-r-1">Bajas</button>
					{{!-- <button type="submit" name="nuevoEquipo" id="nuevoEquipo" class="btn btn-success float-right m-r-1">Nuevo</button> --}}
				</div>
			</div>
		</section>
		<section class="card box-typical">
			<div class="card-block m-b-1">
				<div class="col-md-12">
					<table id="tablaEquipos" class="table table-bordered table-striped table-vcenter js-dataTable-full">
						<thead></thead>
						<tbody></tbody>	
					</table>
				</div>
			</div>
		</section>
		{{> equipos/modal_baja_equipos}}
		{{> equipos/equipos_modal}}
		{{> equipos/modal_equipo_nuevo }}
	</div>
	<script src="/js/lib/jquery/jquery.min.js"></script>
	<script src="/js/lib/tether/tether.min.js"></script>
	<script src="/js/lib/bootstrap/bootstrap.min.js"></script>
	<script src="/js/plugins.js"></script>
	<script src="/js/app.js"></script>
	<script src="/js/lib/datatables-net/datatables.min.js"></script>
	<script src="/js/lib/bootstrap-sweetalert/sweetalert.min.js"></script>
	<script src="/js/lib/summernote/summernote.min.js"></script>
	<script src="/js/lib/fancybox/jquery.fancybox.pack.js"></script>
	<script src="/js/summernote-ES.js"></script>
	<script src="/js/lib/select2/select2.full.min.js"></script>
	<script src="/equipos/equipos.js"></script>
	<script src="/sessions.js"></script>
</body>